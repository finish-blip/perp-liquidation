{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.local/perp-liquidation/settlement-event.schema.json",
  "title": "SettlementEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "correlation_id",
    "client_order_id",
    "exchange_order_id",
    "settlement_sequence",
    "position_id",
    "previous_position_version",
    "new_position_version",
    "settled_quantity",
    "occurred_at"
  ],
  "properties": {
    "event_id": { "type": "string", "minLength": 1, "maxLength": 96 },
    "correlation_id": { "type": "string", "minLength": 1, "maxLength": 96 },
    "client_order_id": { "type": "string", "minLength": 1, "maxLength": 96 },
    "exchange_order_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "settlement_sequence": { "type": "string", "pattern": "^[1-9][0-9]{0,19}$" },
    "position_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "previous_position_version": { "type": "string", "pattern": "^(?:0|[1-9][0-9]{0,19})$" },
    "new_position_version": { "type": "string", "pattern": "^(?:0|[1-9][0-9]{0,19})$" },
    "settled_quantity": {
      "type": "string",
      "pattern": "^(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?$"
    },
    "occurred_at": { "type": "string", "format": "date-time" }
  }
}
