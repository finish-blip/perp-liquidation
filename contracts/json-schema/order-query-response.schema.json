{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.local/perp-liquidation/order-query-response.schema.json",
  "title": "OrderQueryResponse",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["found"],
      "properties": {
        "found": { "const": false }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "found",
        "exchange_order_id",
        "event_sequence",
        "event_type",
        "cumulative_filled_quantity",
        "occurred_at"
      ],
      "properties": {
        "found": { "const": true },
        "exchange_order_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "event_sequence": { "type": "string", "pattern": "^[1-9][0-9]{0,19}$" },
        "event_type": {
          "type": "string",
          "enum": ["ACCEPTED", "PARTIALLY_FILLED", "FILLED", "REJECTED", "CANCELLED"]
        },
        "cumulative_filled_quantity": {
          "type": "string",
          "pattern": "^(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?$"
        },
        "occurred_at": { "type": "string", "format": "date-time" }
      }
    }
  ]
}
