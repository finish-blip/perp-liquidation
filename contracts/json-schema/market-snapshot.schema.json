{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.local/perp-liquidation/market-snapshot.schema.json",
  "title": "MarketSnapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "market",
    "best_bid",
    "best_ask",
    "mark_price",
    "tick_size",
    "step_size",
    "observed_at"
  ],
  "properties": {
    "market": { "type": "string", "minLength": 1, "maxLength": 32 },
    "best_bid": { "type": "string", "pattern": "^(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?$" },
    "best_ask": { "type": "string", "pattern": "^(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?$" },
    "mark_price": { "type": "string", "pattern": "^(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?$" },
    "tick_size": { "type": "string", "pattern": "^(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?$" },
    "step_size": { "type": "string", "pattern": "^(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?$" },
    "observed_at": { "type": "string", "format": "date-time" }
  }
}
