{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.local/perp-liquidation/position-snapshot.schema.json",
  "title": "PositionSnapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "position_id",
    "account_id",
    "risk_unit_id",
    "market",
    "side",
    "version",
    "quantity",
    "reducible_quantity",
    "bankruptcy_price"
  ],
  "properties": {
    "position_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "account_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "risk_unit_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "market": { "type": "string", "minLength": 1, "maxLength": 32 },
    "side": { "type": "string", "enum": ["LONG", "SHORT"] },
    "version": { "type": "string", "pattern": "^(?:0|[1-9][0-9]{0,19})$" },
    "quantity": { "type": "string", "pattern": "^(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?$" },
    "reducible_quantity": { "type": "string", "pattern": "^(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?$" },
    "bankruptcy_price": { "type": "string", "pattern": "^(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?$" }
  }
}
