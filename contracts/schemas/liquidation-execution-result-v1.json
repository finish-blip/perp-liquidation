{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://contracts.example.internal/perp-liquidation/liquidation-execution-result-v1.json",
  "title": "liquidation.execution.result v1",
  "oneOf": [
    { "$ref": "#/definitions/positionResult" },
    { "$ref": "#/definitions/portfolioResult" }
  ],
  "definitions": {
    "decimalString": { "type": "string", "pattern": "^-?(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?$" },
    "nullableDecimal": { "type": ["string", "null"], "pattern": "^-?(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?$" },
    "nullableString": { "type": ["string", "null"] },
    "positionResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version", "event_id", "task_id", "risk_decision_id", "risk_unit_id",
        "decision_sequence", "action", "status", "executed_quantity"
      ],
      "properties": {
        "schema_version": { "const": 1 },
        "event_id": { "type": "string", "minLength": 1 },
        "task_id": { "type": "string", "minLength": 1 },
        "risk_decision_id": { "type": "string", "minLength": 1 },
        "risk_unit_id": { "type": "string", "minLength": 1 },
        "decision_sequence": { "type": "integer", "minimum": 1 },
        "action": { "enum": ["CANCEL_RISK_ORDERS", "REDUCE_POSITION", "LIQUIDATE_POSITION"] },
        "status": { "enum": ["COMPLETED", "REJECTED", "EXPIRED", "SUPERSEDED", "CANCELLED", "MANUAL_REVIEW"] },
        "execution_priority": { "type": "integer", "minimum": 0, "maximum": 1000 },
        "quantity_mode": { "enum": ["EXACT", "UP_TO"] },
        "execution_strategy": { "enum": ["STATIC", "ADAPTIVE"] },
        "execution_urgency": { "enum": ["NORMAL", "HIGH", "CRITICAL"] },
        "child_order_count": { "type": "integer", "minimum": 0 },
        "requested_quantity": { "$ref": "#/definitions/nullableDecimal" },
        "executed_quantity": { "$ref": "#/definitions/decimalString" },
        "average_price": { "$ref": "#/definitions/nullableDecimal" },
        "position_version_before": { "type": ["integer", "null"], "minimum": 1 },
        "position_version_after": { "type": ["integer", "null"], "minimum": 1 },
        "error_code": { "$ref": "#/definitions/nullableString" },
        "error_message": { "$ref": "#/definitions/nullableString" },
        "retryable": { "type": "boolean" },
        "cancelled_order_ids": { "type": "array", "items": { "type": "string" } },
        "authorized_bankruptcy_price": { "$ref": "#/definitions/nullableDecimal" },
        "bankruptcy_price": { "$ref": "#/definitions/nullableDecimal" },
        "bankruptcy_loss": { "$ref": "#/definitions/nullableDecimal" },
        "insurance_fund_covered": { "$ref": "#/definitions/nullableDecimal" },
        "adl_triggered": { "type": "boolean" },
        "adl_request_id": { "$ref": "#/definitions/nullableString" },
        "adl_covered_amount": { "$ref": "#/definitions/nullableDecimal" }
      }
    },
    "portfolioItemResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item_sequence", "task_id", "position_id", "symbol", "authorized_notional", "status", "executed_quantity"],
      "properties": {
        "item_sequence": { "type": "integer", "minimum": 1 },
        "task_id": { "type": "string", "minLength": 1 },
        "position_id": { "type": ["string", "integer"] },
        "symbol": { "type": "string", "minLength": 1 },
        "authorized_notional": { "$ref": "#/definitions/decimalString" },
        "status": { "type": "string", "minLength": 1 },
        "executed_quantity": { "$ref": "#/definitions/decimalString" },
        "average_price": { "$ref": "#/definitions/nullableDecimal" },
        "position_version_before": { "type": ["integer", "null"], "minimum": 1 },
        "position_version_after": { "type": ["integer", "null"], "minimum": 1 },
        "error_code": { "$ref": "#/definitions/nullableString" },
        "error_message": { "$ref": "#/definitions/nullableString" }
      }
    },
    "portfolioResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version", "event_id", "plan_id", "risk_decision_id", "risk_unit_id",
        "decision_sequence", "action", "status", "account_id", "account_version",
        "current_account_version", "item_count", "completed_item_count", "items"
      ],
      "properties": {
        "schema_version": { "const": 1 },
        "event_id": { "type": "string", "minLength": 1 },
        "plan_id": { "type": "string", "minLength": 1 },
        "risk_decision_id": { "type": "string", "minLength": 1 },
        "risk_unit_id": { "type": "string", "minLength": 1 },
        "decision_sequence": { "type": "integer", "minimum": 1 },
        "action": { "const": "LIQUIDATE_PORTFOLIO" },
        "status": { "enum": ["COMPLETED", "FAILED", "CANCELLED", "MANUAL_REVIEW"] },
        "user_id": { "type": ["string", "integer"] },
        "account_id": { "type": "string", "minLength": 1 },
        "account_version": { "type": "integer", "minimum": 1 },
        "current_account_version": { "type": "integer", "minimum": 1 },
        "margin_mode": { "enum": ["CROSS", "PORTFOLIO"] },
        "execution_priority": { "type": "integer", "minimum": 0, "maximum": 1000 },
        "max_total_authorized_notional": { "$ref": "#/definitions/decimalString" },
        "failure_mode": { "const": "STOP_ON_FAILURE" },
        "item_count": { "type": "integer", "minimum": 1 },
        "completed_item_count": { "type": "integer", "minimum": 0 },
        "error_code": { "$ref": "#/definitions/nullableString" },
        "error_message": { "$ref": "#/definitions/nullableString" },
        "items": { "type": "array", "minItems": 1, "items": { "$ref": "#/definitions/portfolioItemResult" } }
      }
    }
  }
}
