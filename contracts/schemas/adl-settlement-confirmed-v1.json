{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://contracts.example.internal/perp-liquidation/adl-settlement-confirmed-v1.json",
  "title": "adl.settlement.confirmed v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_id", "task_id", "adl_request_id", "status", "covered_amount"],
  "properties": {
    "schema_version": { "const": 1 },
    "event_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "adl_request_id": { "type": "string", "minLength": 1 },
    "status": { "const": "COMPLETED" },
    "covered_amount": { "type": "string", "pattern": "^(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?$" },
    "completed_at": { "type": "string", "format": "date-time" },
    "source": { "type": "string", "minLength": 1 }
  }
}
