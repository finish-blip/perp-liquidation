#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative '../lib/perp_liquidation'

application = PerpLiquidation::Application.new(role: :loss_mitigation_worker)
interval = Float(ENV.fetch('LOSS_MITIGATION_WORKER_INTERVAL_SECONDS', '1'))

loop do
  application.loss_mitigation_worker.perform
  sleep(interval)
end
