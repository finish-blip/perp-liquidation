#!/usr/bin/env ruby
# frozen_string_literal: true

require 'rack'
require_relative '../integration/reference_services_app'

application = PerpLiquidation::Integration::ReferenceServicesApp.new
Rack::Server.start(
  app: application,
  Host: ENV.fetch('BIND_HOST', '0.0.0.0'),
  Port: Integer(ENV.fetch('PORT', '3101'))
)
