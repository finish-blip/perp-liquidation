{
  "name": "perp-liquidation-node",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "description": "Standalone Node.js liquidation engine for perpetual contracts.",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "pnpm run lint && pnpm run build && pnpm test",
    "dev:api": "tsx src/bootstrap/api.ts",
    "smoke:binance": "tsx src/bootstrap/binance-market-smoke.ts",
    "smoke:rabbit": "node bin/rabbit-expired-smoke.mjs",
    "dev:stream-consumer": "tsx src/bootstrap/stream-consumer.ts",
    "dev:rabbit-consumer": "tsx src/bootstrap/rabbit-command-consumer.ts",
    "dev:worker": "tsx src/bootstrap/worker.ts",
    "start:api": "node dist/src/bootstrap/api.js",
    "start:stream-consumer": "node dist/src/bootstrap/stream-consumer.js",
    "start:rabbit-consumer": "node dist/src/bootstrap/rabbit-command-consumer.js",
    "start:worker": "node dist/src/bootstrap/worker.js",
    "test": "vitest run",
    "test:e2e:real": "vitest run --config vitest.e2e.config.mjs",
    "test:watch": "vitest",
    "lint": "eslint ."
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "amqplib": "^2.0.1",
    "decimal.js": "^10.5.0",
    "fastify": "^5.4.0",
    "ioredis": "^5.6.1",
    "mysql2": "^3.14.1",
    "pino": "^9.7.0",
    "prom-client": "^15.1.3",
    "undici": "^7.11.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^24.0.10",
    "eslint": "^9.30.1",
    "testcontainers": "^11.0.3",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.4"
  }
}
